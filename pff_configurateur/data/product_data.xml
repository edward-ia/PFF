<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="product_pff_configure" model="product.template">
        <field name="name">Produit configuré PFF</field>
        <field name="type">consu</field>
        <field name="sale_ok" eval="True"/>
        <field name="purchase_ok" eval="False"/>
        <field name="list_price">0.0</field>
    </record>

    <!-- Phase D : produit générique pour le bon d'achat verre + fournisseur -->
    <record id="product_pff_thermos" model="product.template">
        <field name="name">Thermos (verre scellé)</field>
        <field name="type">consu</field>
        <field name="sale_ok" eval="False"/>
        <field name="purchase_ok" eval="True"/>
        <field name="list_price">0.0</field>
    </record>
    <!-- Le fournisseur du verre (ex. Multiver) N'EST PAS créé ici : c'est du
         master data que l'utilisateur gère dans Contacts. Le bon d'achat verre
         est créé sans fournisseur ; l'acheteur le choisit avant de valider. -->
</odoo>
