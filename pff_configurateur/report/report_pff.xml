<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action d'impression : Bons de travail (feuilles de production) -->
    <record id="action_report_pff_bt" model="ir.actions.report">
        <field name="name">Bons de travail</field>
        <field name="model">pff.configuration</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pff_configurateur.report_pff_bt</field>
        <field name="report_file">pff_configurateur.report_pff_bt</field>
        <field name="binding_model_id" ref="model_pff_configuration"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_pff_bt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="d" t-value="doc._get_bt_data()"/>
                <t t-set="pcol" t-value="{'Scie':'#E8720C','Poinçon machinage':'#E8720C','Soudage':'#2E9BD6','Sous-ensemble':'#C463C9','Assemblage':'#C463C9','Achat sur commande':'#7A7A7A','Validation':'#059669'}"/>
                <div class="page" style="font-family:Arial,Helvetica,sans-serif;color:#111;font-size:11px;">

                    <!-- ===== Feuilles de production par composante ===== -->
                    <t t-foreach="d['feuilles']" t-as="f">
                        <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:4px;">
                            <div style="font-weight:bold;font-size:13px;">Feuille de production</div>
                            <div style="text-align:right;font-size:9px;color:#333;">
                                Commande <span t-esc="doc.name"/> · BT <span t-esc="doc.name"/><br/>
                                <span t-esc="doc.date_order"/>
                            </div>
                        </div>
                        <div style="border:1px solid #111;">
                            <div style="font-weight:bold;font-size:12px;padding:4px 8px;border-bottom:1px solid #111;" t-esc="f['name']"/>
                            <table style="width:100%;border-collapse:collapse;">
                                <thead>
                                    <tr style="border-bottom:1px solid #111;">
                                        <td style="font-weight:bold;font-size:9px;padding:4px 6px;">COMM/ITEM</td>
                                        <td style="font-weight:bold;font-size:9px;padding:4px 6px;">Pièces</td>
                                        <td style="font-weight:bold;font-size:9px;padding:4px 6px;text-align:right;">Longueur TIGER</td>
                                        <td style="font-weight:bold;font-size:9px;padding:4px 6px;text-align:center;">Qté</td>
                                        <td style="font-weight:bold;font-size:9px;padding:4px 6px;text-align:right;">Longueur</td>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="f['rows']" t-as="r" style="border-bottom:1px solid #d5d5d5;">
                                        <td style="padding:3px 6px;font-size:9px;white-space:nowrap;"><span t-esc="doc.name"/> <b t-esc="r['item']"/></td>
                                        <td style="padding:3px 6px;font-size:10px;"><b t-esc="r['code']"/> <span t-esc="r['desc']"/></td>
                                        <td style="padding:3px 6px;font-size:10px;text-align:right;" t-esc="r['tiger']"/>
                                        <td style="padding:3px 6px;font-size:10px;text-align:center;" t-esc="r['qte']"/>
                                        <td style="padding:3px 6px;font-size:10px;text-align:right;" t-esc="r['tiger']"/>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div style="margin-top:10px;">
                            <span t-foreach="f['postes']" t-as="p"
                                  t-attf-style="background:{{ pcol.get(p,'#888') }};color:#fff;padding:5px 16px;margin-right:4px;font-weight:bold;font-size:9px;"
                                  t-esc="p"/>
                        </div>
                        <p style="page-break-after:always;"/>
                    </t>

                    <!-- ===== Thermos (achat sur commande) ===== -->
                    <t t-if="d['thermos']">
                        <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:4px;">
                            <div style="font-weight:bold;font-size:13px;">Feuille de production — THERMOS (achat sur commande)</div>
                            <div style="text-align:right;font-size:9px;color:#333;">Commande <span t-esc="doc.name"/></div>
                        </div>
                        <div style="border:1px solid #111;">
                            <table style="width:100%;border-collapse:collapse;">
                                <thead><tr style="border-bottom:1px solid #111;">
                                    <td style="font-weight:bold;font-size:9px;padding:4px 6px;">Description</td>
                                    <td style="font-weight:bold;font-size:9px;padding:4px 6px;text-align:center;width:120px;">Qté / Unité</td>
                                </tr></thead>
                                <tbody>
                                    <tr t-foreach="d['thermos']" t-as="t" style="border-bottom:1px solid #d5d5d5;">
                                        <td style="padding:3px 6px;font-size:10px;">(<span t-esc="doc.name"/>/<span t-esc="t['item']"/>) <span t-esc="t['desc']"/></td>
                                        <td style="padding:3px 6px;font-size:10px;text-align:center;" t-esc="t['qte']"/>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div style="margin-top:10px;">
                            <span style="background:#7A7A7A;color:#fff;padding:5px 16px;margin-right:4px;font-weight:bold;font-size:9px;">Achat sur commande</span>
                            <span style="background:#C463C9;color:#fff;padding:5px 16px;font-weight:bold;font-size:9px;">Assemblage</span>
                        </div>
                        <p style="page-break-after:always;"/>
                    </t>

                    <!-- ===== Étiquettes d'assemblage (1 par item) ===== -->
                    <t t-foreach="d['etiquettes']" t-as="e">
                        <div style="text-align:center;font-size:9px;color:#E8720C;font-weight:bold;margin-bottom:2px;">Assemblage — étiquette collée sur la fenêtre (la flèche = sens d'ouverture)</div>
                        <div style="display:flex;align-items:flex-start;gap:18px;margin-top:8px;">
                            <div style="width:400px;">
                                <div style="border:1px solid #111;">
                                    <div style="border-bottom:1px solid #111;padding:2px 6px;display:flex;justify-content:space-between;align-items:baseline;">
                                        <span style="font-size:8px;color:#333;"># Commande</span>
                                        <span style="font-weight:bold;font-size:12px;"><span t-esc="e['commande']"/> \ <span t-esc="e['item']"/></span>
                                        <span style="font-weight:bold;font-size:12px;" t-esc="doc.name"/>
                                    </div>
                                    <div style="border-bottom:1px solid #111;padding:2px 6px;font-size:10px;"><span style="font-size:8px;color:#333;">LIVRÉ À </span><b t-esc="doc.partner_id.name"/></div>
                                    <div style="border-bottom:1px solid #111;padding:2px 6px;font-size:10px;"><span style="font-size:8px;color:#333;">VENDU À </span><span t-esc="doc.partner_id.name"/></div>
                                    <div style="border-bottom:1px solid #111;padding:2px 6px;font-size:10px;"><span t-esc="e['type']"/> <span t-if="e['section']">· <span t-esc="e['section']"/></span></div>
                                    <div style="padding:5px 6px;font-size:10px;">CADRE : <span t-esc="e['width']"/> × <span t-esc="e['height']"/> mm</div>
                                </div>
                                <div style="font-size:9px;line-height:1.6;margin-top:6px;">
                                    <div t-foreach="e['bullets']" t-as="b">- <span t-esc="b"/></div>
                                </div>
                                <div style="height:38px;width:200px;margin-top:14px;background:repeating-linear-gradient(90deg,#111 0 2px,#fff 2px 3px,#111 3px 5px,#fff 5px 8px,#111 8px 9px,#fff 9px 12px);"/>
                                <div style="font-size:11px;letter-spacing:2px;" t-esc="e['barcode']"/>
                            </div>
                            <div style="text-align:center;">
                                <div style="font-size:26px;font-weight:800;line-height:1.05;">
                                    <t t-foreach="doc.name" t-as="ch"><span t-esc="ch"/><br/></t>
                                </div>
                                <div style="font-size:34px;font-weight:800;margin-top:20px;" t-esc="e['item']"/>
                            </div>
                        </div>
                        <p style="page-break-after:always;"/>
                    </t>

                    <!-- ===== Validation (contrôle qualité) ===== -->
                    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:4px;">
                        <div style="font-weight:bold;font-size:13px;">Feuille de validation — Contrôle qualité</div>
                        <div style="text-align:right;font-size:9px;color:#333;">Commande <span t-esc="doc.name"/></div>
                    </div>
                    <div style="border:1px solid #111;">
                        <div style="font-weight:bold;font-size:12px;padding:4px 8px;border-bottom:1px solid #111;">VALIDATION — avant expédition</div>
                        <table style="width:100%;border-collapse:collapse;">
                            <thead><tr style="border-bottom:1px solid #111;">
                                <td style="font-weight:bold;font-size:9px;padding:5px 6px;">Item</td>
                                <td style="font-weight:bold;font-size:9px;padding:5px 6px;">Type · dimensions</td>
                                <td style="font-weight:bold;font-size:9px;padding:5px 6px;text-align:center;">Dim. cadre</td>
                                <td style="font-weight:bold;font-size:9px;padding:5px 6px;text-align:center;">Équerrage</td>
                                <td style="font-weight:bold;font-size:9px;padding:5px 6px;text-align:center;">Verre / thermos</td>
                                <td style="font-weight:bold;font-size:9px;padding:5px 6px;text-align:center;">Quincaillerie</td>
                                <td style="font-weight:bold;font-size:9px;padding:5px 6px;text-align:center;">Moustiquaire</td>
                                <td style="font-weight:bold;font-size:9px;padding:5px 6px;text-align:center;">Egress</td>
                            </tr></thead>
                            <tbody>
                                <tr t-foreach="d['validation']" t-as="v" style="border-bottom:1px solid #d5d5d5;">
                                    <td style="padding:5px 6px;font-size:10px;text-align:center;" t-esc="v['item']"/>
                                    <td style="padding:5px 6px;font-size:10px;"><span t-esc="v['type']"/> · <span t-esc="v['width']"/> × <span t-esc="v['height']"/></td>
                                    <td style="padding:5px 6px;text-align:center;"><span style="display:inline-block;width:14px;height:14px;border:1.5px solid #333;"/></td>
                                    <td style="padding:5px 6px;text-align:center;"><span style="display:inline-block;width:14px;height:14px;border:1.5px solid #333;"/></td>
                                    <td style="padding:5px 6px;text-align:center;"><span style="display:inline-block;width:14px;height:14px;border:1.5px solid #333;"/></td>
                                    <td style="padding:5px 6px;text-align:center;"><span style="display:inline-block;width:14px;height:14px;border:1.5px solid #333;"/></td>
                                    <td style="padding:5px 6px;text-align:center;"><span style="display:inline-block;width:14px;height:14px;border:1.5px solid #333;"/></td>
                                    <td style="padding:5px 6px;font-size:10px;text-align:center;"><b t-if="v['egress']">OUI ✓</b><span t-if="not v['egress']">—</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div style="display:flex;gap:24px;margin-top:16px;font-size:11px;">
                        <div style="flex:1;border-top:1px solid #333;padding-top:3px;">Contrôlé par :</div>
                        <div style="flex:1;border-top:1px solid #333;padding-top:3px;">Date :</div>
                        <div style="flex:1;border-top:1px solid #333;padding-top:3px;">Signature :</div>
                    </div>

                </div>
            </t>
        </t>
    </template>

    <!-- ============================================================= -->
    <!-- Bon d'achat verre — reprend le FORMAT Fusion (« Commande achat ») -->
    <!-- Données 100% dynamiques : n° = po.name, date = maintenant,        -->
    <!-- Envoyé par = utilisateur, fournisseur + adresse = fiche réelle.   -->
    <!-- ============================================================= -->
    <record id="paperformat_pff_po" model="report.paperformat">
        <field name="name">PFF Bon d'achat</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">6</field>
        <field name="margin_bottom">6</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">6</field>
        <field name="dpi">90</field>
    </record>
    <!-- Le bon d'achat Fusion REMPLACE le rapport d'achat standard Odoo.     -->
    <!-- On redirige les DEUX actions natives (bon de commande + demande de   -->
    <!-- prix) vers notre gabarit et on les renomme « Bon d'achat » : le       -->
    <!-- bouton « Imprimer » de l'en-tête sort directement le format Fusion,   -->
    <!-- l'ancien PDF anglais « Purchase Order » disparaît (plus de doublon).  -->
    <record id="purchase.action_report_purchase_order" model="ir.actions.report">
        <field name="name">Bon d'achat</field>
        <field name="report_name">pff_configurateur.report_pff_po</field>
        <field name="report_file">pff_configurateur.report_pff_po</field>
        <field name="paperformat_id" ref="paperformat_pff_po"/>
    </record>

    <template id="report_pff_po">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="po">
                <t t-set="tot" t-value="sum(po.order_line.mapped('product_qty'))"/>
                <div class="page" style="font-family:Arial,Helvetica,sans-serif;color:#111;font-size:12px;">

                    <!-- ===== En-tête (tableau : fiable en PDF, contrairement au flex) ===== -->
                    <table style="width:100%;border-collapse:collapse;">
                        <tr style="vertical-align:top;">
                            <td style="width:34%;">
                                <img t-if="po.company_id.logo" t-att-src="image_data_uri(po.company_id.logo)" style="max-height:60px;max-width:240px;"/>
                                <div t-else="" style="font-weight:bold;font-size:17px;color:#0a63a8;">PORTES ET FENÊTRES FUSION</div>
                            </td>
                            <td style="width:33%;text-align:center;font-size:15px;padding-top:6px;">
                                Commande achat # <span style="font-weight:bold;" t-esc="po.name"/>
                            </td>
                            <td style="width:33%;text-align:right;font-size:10px;color:#333;">
                                <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M:%S')"/><br/>
                                Page: 1<br/>
                                Envoye par: <span t-esc="(po.user_id or po.create_uid).name"/>
                            </td>
                        </tr>
                    </table>

                    <!-- ===== Dates + fournisseur ===== -->
                    <div style="margin:16px 0 0 34%;font-size:12px;">
                        Date achat :<span style="margin-left:8px;" t-esc="po.date_order.strftime('%Y-%m-%d') if po.date_order else ''"/><br/>
                        Date requise :<span style="margin-left:8px;" t-esc="po.date_planned.strftime('%Y-%m-%d') if po.date_planned else ''"/>
                    </div>
                    <div style="margin:14px 0 0 34%;font-size:12px;line-height:1.35;">
                        <div style="font-weight:bold;" t-esc="po.partner_id.name"/>
                        <div t-if="po.partner_id.street" t-esc="po.partner_id.street"/>
                        <div>
                            <span t-esc="po.partner_id.city or ''"/>
                            <t t-if="po.partner_id.state_id"> (<span t-esc="po.partner_id.state_id.name"/>)</t>
                            <span t-esc="po.partner_id.zip or ''"/>
                        </div>
                    </div>

                    <!-- ===== Tableau des lignes ===== -->
                    <table style="width:100%;border-collapse:collapse;margin-top:20px;font-size:12px;">
                        <thead>
                            <tr style="border-top:1px solid #000;border-bottom:1px solid #000;">
                                <th style="text-align:left;padding:6px 8px;">Description</th>
                                <th style="text-align:right;padding:6px 8px;width:130px;">Qte / Unite</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="po.order_line" t-as="l" t-att-style="'background:#ececec;' if l_index % 2 == 0 else ''">
                                <td style="padding:6px 8px;" t-esc="l.name"/>
                                <td style="padding:6px 8px;text-align:right;" t-esc="int(l.product_qty)"/>
                            </tr>
                        </tbody>
                    </table>
                    <div style="border-top:1px solid #000;"/>

                    <!-- ===== Commentaire + total (tableau) ===== -->
                    <table style="width:100%;border-collapse:collapse;margin-top:12px;font-size:12px;">
                        <tr style="vertical-align:top;">
                            <td style="text-align:left;"><span style="font-weight:bold;">Commentaire:</span> Production (<span t-esc="po.origin or ''"/>)</td>
                            <td style="width:42%;text-align:center;"><span style="font-weight:bold;">Total</span><span style="margin-left:34px;" t-esc="int(tot)"/></td>
                        </tr>
                    </table>

                </div>
            </t>
        </t>
    </template>

    <!-- ============================================================= -->
    <!-- Commande CLIENT — format Fusion (données dynamiques)           -->
    <!-- ============================================================= -->
    <record id="action_report_pff_commande" model="ir.actions.report">
        <field name="name">Commande client (Fusion)</field>
        <field name="model">pff.configuration</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pff_configurateur.report_pff_commande</field>
        <field name="report_file">pff_configurateur.report_pff_commande</field>
        <field name="paperformat_id" ref="paperformat_pff_po"/>
        <field name="binding_model_id" ref="model_pff_configuration"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_pff_commande">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="d" t-value="doc._get_commande_data()"/>
                <t t-set="L" t-value="d['L']"/>
                <!-- Le <div class="article"> est REQUIS : sans lui, Odoo n'enveloppe pas
                     le corps dans minimal_layout et perd le charset UTF-8 (accents cassés). -->
                <div class="article" t-att-data-oe-model="doc._name" t-att-data-oe-id="doc.id">
                <div class="page" style="font-family:Arial,Helvetica,sans-serif;color:#111;font-size:11px;">

                    <!-- En-tête -->
                    <table style="width:100%;border-collapse:collapse;">
                        <tr style="vertical-align:top;">
                            <td style="width:34%;">
                                <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)" style="max-height:58px;max-width:240px;"/>
                                <div t-else="" style="font-weight:bold;font-size:16px;color:#0a63a8;" t-out="L['company_name_big']"/>
                            </td>
                            <td style="width:33%;text-align:center;">
                                <div style="font-size:15px;">Commande <span style="font-weight:bold;" t-esc="doc.name"/></div>
                                <div style="font-size:9px;">#Client: <span t-esc="d['client_ref']"/>, #Soumission: <span t-esc="d['soumission']"/></div>
                            </td>
                            <td style="width:33%;text-align:right;font-size:9px;color:#333;">
                                <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M:%S')"/><br/>Page : 1 (MAJ 1.0.3)
                            </td>
                        </tr>
                    </table>

                    <!-- Vendu à / Livré à -->
                    <table style="width:100%;border-collapse:collapse;margin-top:6px;font-size:10px;">
                        <tr style="vertical-align:top;">
                            <td style="width:50%;border:1px solid #000;padding:5px;">
                                <span style="font-size:8px;" t-out="L['vendu_a']"/> <span style="font-weight:bold;" t-out="d['vendu']['name']"/><br/>
                                <span t-out="d['vendu']['street']"/><br/>
                                <span t-out="d['vendu']['cityline']"/><br/>
                                <span t-out="d['vendu']['phone']"/>
                            </td>
                            <td style="width:50%;border:1px solid #000;padding:5px;">
                                <span style="font-size:8px;" t-out="L['livre_a']"/> <span style="font-weight:bold;" t-out="d['livre']['name']"/><br/>
                                <span t-out="d['livre']['street']"/><br/>
                                <span t-out="d['livre']['cityline']"/><br/>
                                <span t-out="d['livre']['phone']"/>
                            </td>
                        </tr>
                    </table>
                    <table style="width:100%;border-collapse:collapse;font-size:10px;">
                        <tr style="vertical-align:top;">
                            <td style="width:50%;border:1px solid #000;padding:4px;"><b>DATE</b> <span t-esc="doc.date_order.strftime('%Y-%m-%d') if doc.date_order else ''"/><span style="display:inline-block;width:18px;"></span><b>REQUIS</b> <span t-esc="doc.date_delivery.strftime('%Y-%m-%d') if doc.date_delivery else ''"/></td>
                            <td style="width:50%;border:1px solid #000;padding:4px;"><b>CONDITION</b> Net 30 JRS<span style="display:inline-block;width:18px;"></span><b t-out="L['expedition']"/></td>
                        </tr>
                    </table>

                    <!-- Items -->
                    <t t-foreach="d['items']" t-as="it">
                        <table style="width:100%;border-collapse:collapse;font-size:10px;margin-top:6px;">
                            <tr>
                                <td style="border:1px solid #000;padding:3px;text-align:center;width:5%;"><b>Item</b><br/><span t-esc="it['idx']"/></td>
                                <td style="border:1px solid #000;padding:3px;text-align:center;width:7%;"><b>Largeur</b><br/><span t-esc="it['w_in']"/></td>
                                <td style="border:1px solid #000;padding:3px;text-align:center;width:7%;"><b>Hauteur</b><br/><span t-esc="it['h_in']"/></td>
                                <td style="border:1px solid #000;padding:3px;"><b><span t-out="it['name']"/></b></td>
                                <td style="border:1px solid #000;padding:3px;text-align:right;width:13%;"><b>Prix unitaire</b><br/><span t-esc="'%.2f $' % it['price_unit']"/></td>
                                <td style="border:1px solid #000;padding:3px;text-align:center;width:5%;"><b t-out="L['qte']"/><br/><span t-esc="it['qty']"/></td>
                                <td style="border:1px solid #000;padding:3px;text-align:right;width:13%;"><b>Prix total</b><br/><span t-esc="'%.2f $' % it['subtotal']"/></td>
                            </tr>
                        </table>
                        <div style="font-size:8px;font-weight:bold;margin:2px 0 1px;" t-out="L['dessin_vue']"/>
                        <table style="width:100%;border-collapse:collapse;">
                            <tr style="vertical-align:top;">
                                <td style="width:120px;"><t t-out="it['svg']"/></td>
                                <td style="font-size:9px;line-height:1.35;padding-left:6px;">
                                    <t t-foreach="it['specs']" t-as="sp"><span t-out="sp"/><br/></t>
                                </td>
                            </tr>
                        </table>
                    </t>

                    <!-- Totaux + signatures -->
                    <table style="width:100%;border-collapse:collapse;margin-top:12px;font-size:10px;">
                        <tr style="vertical-align:top;">
                            <td style="width:60%;padding:4px;">
