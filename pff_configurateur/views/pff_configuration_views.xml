<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- LISTE -->
    <record id="view_pff_configuration_list" model="ir.ui.view">
        <field name="name">pff.configuration.list</field>
        <field name="model">pff.configuration</field>
        <field name="arch" type="xml">
            <list string="Produits configurés">
                <field name="name"/>
                <field name="date_order"/>
                <field name="date_delivery"/>
                <field name="partner_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="amount_total" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'production'"
                       decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <!-- FORMULAIRE -->
    <record id="view_pff_configuration_form" model="ir.ui.view">
        <field name="name">pff.configuration.form</field>
        <field name="model">pff.configuration</field>
        <field name="arch" type="xml">
            <form string="Produit configuré">
                <header>
                    <!-- Nouvelle configuration : violet quand vide, blanc quand une config existe -->
                    <button name="action_open_configurator" type="object"
                            string="Nouvelle configuration" class="btn-primary"
                            icon="fa-plus" invisible="line_ids"/>
                    <button name="action_open_configurator" type="object"
                            string="Nouvelle configuration" class="btn-secondary"
                            icon="fa-plus" invisible="not line_ids"/>
                    <button name="action_create_quotation" type="object"
                            string="Créer un devis" class="btn-primary"
                            invisible="sale_order_id"/>
                    <button name="action_production" type="object"
                            string="Lancer en fabrication" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_done" type="object"
                            string="Marquer terminé" invisible="state != 'production'"/>
                    <button name="action_draft" type="object"
                            string="Remettre en brouillon" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,production,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_quotation" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="not sale_order_id">
                            <div class="o_stat_info"><span class="o_stat_text">Devis</span></div>
                        </button>
                        <button name="action_view_purchase" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="not purchase_order_id">
                            <div class="o_stat_info"><span class="o_stat_text">Bon d'achat</span></div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="lead_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="date_order"/>
                            <field name="date_delivery"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Produits configurés" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="family"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal" widget="monetary"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <button name="action_edit_line" type="object"
                                            string="Reprendre" icon="fa-cubes"
                                            title="Reprendre la configuration de ce produit"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_total" widget="monetary"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_pff_configuration" model="ir.actions.act_window">
        <field name="name">Commandes client</field>
        <field name="res_model">pff.configuration</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Créer une nouvelle commande configurée</p>
        </field>
    </record>
</odoo>
