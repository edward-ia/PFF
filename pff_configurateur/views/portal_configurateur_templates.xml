<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Carte « Configurer un produit » sur l'accueil du portail (Mon compte) -->
    <template id="portal_my_home_pff_config" inherit_id="portal.portal_my_home"
              name="Portail PFF : Configurer un produit" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <div class="col-12 col-md-6 col-lg-4 mb-3">
                <a href="/my/configurateur" class="d-block h-100 text-decoration-none">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex align-items-center">
                            <i class="fa fa-cubes fa-2x me-3 text-primary" role="img"
                               aria-label="Configurer un produit"/>
                            <div>
                                <h5 class="mb-1 text-body">Configurer un produit</h5>
                                <small class="text-muted">Créez votre soumission de portes et fenêtres.</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-12 col-md-6 col-lg-4 mb-3">
                <a href="/my/quotes" class="d-block h-100 text-decoration-none">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex align-items-center">
                            <i class="fa fa-file-text-o fa-2x me-3 text-primary" role="img"
                               aria-label="Mes devis"/>
                            <div>
                                <h5 class="mb-1 text-body">Mes devis</h5>
                                <small class="text-muted">Consultez et signez vos soumissions.</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        </xpath>
    </template>

    <!-- Colonne « Statut de fabrication » dans la liste des COMMANDES du portail
         (à côté du statut d'expédition ; s'affiche seulement pour les commandes). -->
    <template id="portal_my_orders_pff_fab" inherit_id="sale.portal_my_orders"
              name="Portail PFF : statut de fabrication">
        <xpath expr="//thead/tr/th[last()]" position="before">
            <th class="text-center">Statut de fabrication</th>
        </xpath>
        <xpath expr="//tbody//t[@t-foreach='orders']/tr/td[last()]" position="before">
            <td class="text-center">
                <span t-if="order.pff_fabrication_status"
                      class="badge rounded-pill text-bg-info">
                    <t t-esc="order.pff_fabrication_status"/>
                </span>
                <span t-else="" class="text-muted">—</span>
            </td>
        </xpath>
    </template>

    <!-- Page portail : le configurateur 3D en pleine page -->
    <template id="portal_configurateur_page" name="Portail PFF : Configurateur">
        <t t-call="portal.portal_layout">
            <t t-set="no_breadcrumbs" t-value="True"/>
            <!-- Pleine largeur : on sort du conteneur centré du portail
                 (full-bleed) pour donner tout l'écran au configurateur. -->
            <div class="o_pff_portal_configurator"
                 style="position:relative; left:50%; right:50%; width:100vw;
                        margin-left:-50vw; margin-right:-50vw;
                        height: calc(100vh - 120px); min-height: 560px;">
                <iframe src="/pff_configurateur/static/configurateur.html?v=28&amp;portal=1"
                        style="width:100%; height:100%; border:0;" allow="fullscreen"/>
            </div>
        </t>
    </template>

</odoo>
